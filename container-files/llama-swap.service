[Unit]
Description=Llama-swap Service
After=network.target
After=prepare-llama.service
Requires=prepare-llama.service

[Service]
#WorkingDirectory=/app
Environment=LLAMA_CACHE=/root/data/models
#Environment=HSA_OVERRIDE_GFX_VERSION=10.3.0
Environment=ROCR_VISIBLE_DEVICES=0

ExecStart=/usr/local/bin/llama-swap --config /root/data/config.yaml --watch-config
RestartSec=2s

Restart=always
User=root

[Install]
WantedBy=multi-user.target